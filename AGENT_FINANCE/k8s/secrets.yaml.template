# Template for Kubernetes secrets
# Copy to secrets.yaml and fill in actual values
# Then apply with: kubectl apply -f secrets.yaml

apiVersion: v1
kind: Secret
metadata:
  name: amcis-secrets
  namespace: amcis-finance
type: Opaque
stringData:
  database-url: "postgresql://amcis:YOUR_PASSWORD@postgres:5432/amcis_finance"
  redis-url: "redis://redis:6379/0"
  jwt-secret: "YOUR_JWT_SECRET_HERE"
  
  # Exchange API keys (encrypted)
  binance-api-key: "YOUR_BINANCE_KEY"
  binance-api-secret: "YOUR_BINANCE_SECRET"
  coinbase-api-key: "YOUR_COINBASE_KEY"
  coinbase-api-secret: "YOUR_COINBASE_SECRET"
  
  # Blockchain RPC endpoints
  ethereum-rpc: "YOUR_ETH_RPC_URL"
  arbitrum-rpc: "YOUR_ARB_RPC_URL"
  
  # Wallet private keys (encrypted with KMS)
  hot-wallet-key: "ENCRYPTED_KEY"
