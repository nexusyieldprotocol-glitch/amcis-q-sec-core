# AMCIS Unified Environment Configuration
# ========================================
# Copy this file to .env and fill in your values

# =============================================================================
# AMCIS Core Configuration
# =============================================================================

# Environment: development, staging, production
AMCIS_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
AMCIS_LOG_LEVEL=DEBUG

# Configuration file path
AMCIS_CONFIG_PATH=/app/config/kernel.conf

# Data directories
AMCIS_DATA_DIR=/var/lib/amcis
AMCIS_LOGS_DIR=/var/log/amcis

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

DATABASE_URL=postgresql://amcis:amcis@localhost:5432/amcis
# Or individual components:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amcis
DB_USER=amcis
DB_PASSWORD=amcis
DB_SSL_MODE=disable

# =============================================================================
# Cache Configuration (Redis)
# =============================================================================

REDIS_URL=redis://localhost:6379/0
# Or individual components:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# HashiCorp Vault Configuration
# =============================================================================

VAULT_ADDR=http://localhost:8200
VAULT_NAMESPACE=

# Authentication - choose ONE method:

# Method 1: Static Token (development only)
VAULT_TOKEN=dev-token

# Method 2: Kubernetes Auth (production)
# VAULT_ROLE=amcis-core
# VAULT_AUTH_MOUNT=kubernetes
# VAULT_JWT_PATH=/var/run/secrets/kubernetes.io/serviceaccount/token

# Method 3: AppRole Auth
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=
# VAULT_APPROLE_MOUNT=approle

# =============================================================================
# Cryptography Configuration
# =============================================================================

# Master encryption key (base64 encoded, 32 bytes)
# Generate with: openssl rand -base64 32
AMCIS_MASTER_KEY=

# TPM configuration
AMCIS_ENABLE_TPM=false
TPM_DEVICE_PATH=/dev/tpm0

# HSM configuration
AMCIS_ENABLE_HSM=false
HSM_LIBRARY_PATH=/usr/lib/pkcs11/libCryptoki2_64.so
HSM_SLOT=0
HSM_PIN=

# Post-Quantum Cryptography
AMCIS_PQC_ENABLED=true
AMCIS_PQC_DEFAULT_KEM=ML-KEM-768
AMCIS_PQC_DEFAULT_SIGN=ML-DSA-65
AMCIS_PQC_HYBRID_MODE=true

# =============================================================================
# Monitoring & Observability
# =============================================================================

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Tracing (Jaeger)
TRACING_ENABLED=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Health checks
HEALTH_CHECK_INTERVAL=30

# =============================================================================
# Security Configuration
# =============================================================================

# Anomaly detection
ANOMALY_DETECTION_ENABLED=true
ANOMALY_THRESHOLD=0.75
ANOMALY_BASELINE_WINDOW=86400

# Threat intelligence
THREAT_INTEL_ENABLED=true
THREAT_INTEL_FEED_URL=
THREAT_INTEL_API_KEY=

# Audit logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365

# =============================================================================
# Network Configuration
# =============================================================================

# API server
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4

# TLS/SSL
TLS_ENABLED=false
TLS_CERT_PATH=/etc/amcis/certs/server.crt
TLS_KEY_PATH=/etc/amcis/certs/server.key
TLS_CA_PATH=/etc/amcis/certs/ca.crt

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# AI/ML Configuration
# =============================================================================

# AI model paths
AI_MODEL_PATH=/var/lib/amcis/models
AI_INFERENCE_DEVICE=cpu

# RAG (Retrieval Augmented Generation)
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_VECTOR_STORE=chroma
RAG_VECTOR_STORE_PATH=/var/lib/amcis/vectors

# =============================================================================
# Integration Configuration
# =============================================================================

# AMCIS 9.0 (TypeScript) integration
AMCIS_9_API_URL=http://localhost:3001
AMCIS_9_API_KEY=

# SIEM integration
SIEM_ENABLED=false
SIEM_TYPE=splunk  # splunk, elk, qradar
SIEM_URL=
SIEM_API_KEY=

# SOAR integration
SOAR_ENABLED=false
SOAR_TYPE=phantom  # phantom, demisto, resilient
SOAR_URL=
SOAR_API_KEY=

# =============================================================================
# Development Configuration
# =============================================================================

# Hot reload
HOT_RELOAD=true

# Debug mode
DEBUG=false

# Profiling
PROFILING_ENABLED=false
PROFILING_PORT=8081

# Test mode
TEST_MODE=false

# =============================================================================
# Commercial/Licensing
# =============================================================================

# License key
AMCIS_LICENSE_KEY=

# License server (for floating licenses)
LICENSE_SERVER_URL=
LICENSE_SERVER_TOKEN=

# Watermarking
WATERMARK_ENABLED=true
WATERMARK_SECRET=
