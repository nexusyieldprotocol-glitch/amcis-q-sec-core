{
    "app-id": "com.amcis.SecurityPlatform",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.python3.11"
    ],
    "command": "amcis",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=all",
        "--filesystem=home",
        "--filesystem=/tmp",
        "--filesystem=/var/log",
        "--talk-name=org.freedesktop.Notifications",
        "--system-talk-name=org.freedesktop.NetworkManager",
        "--talk-name=org.freedesktop.Flatpak"
    ],
    "build-options": {
        "env": {
            "PYTHONPATH": "/app/lib/python3.11/site-packages"
        }
    },
    "modules": [
        {
            "name": "python3-requirements",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --prefix=/app cryptography pydantic fastapi uvicorn sqlalchemy redis prometheus-client psutil pyyaml requests aiohttp numpy pandas pyjwt passlib python-jose bcrypt"
            ]
        },
        {
            "name": "amcis",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/share/amcis",
                "cp -r ../AMCIS_Q_SEC_CORE/* /app/share/amcis/",
                "mkdir -p /app/bin",
                "install -D amcis-launcher.sh /app/bin/amcis",
                "install -D amcis-dashboard.sh /app/bin/amcis-dashboard",
                "install -D com.amcis.SecurityPlatform.desktop /app/share/applications/com.amcis.SecurityPlatform.desktop",
                "install -D com.amcis.SecurityPlatform.metainfo.xml /app/share/metainfo/com.amcis.SecurityPlatform.metainfo.xml",
                "install -D ../assets/amcis_icon.png /app/share/icons/hicolor/256x256/apps/com.amcis.SecurityPlatform.png"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "amcis-launcher.sh"
                },
                {
                    "type": "file",
                    "path": "amcis-dashboard.sh"
                },
                {
                    "type": "file",
                    "path": "com.amcis.SecurityPlatform.desktop"
                },
                {
                    "type": "file",
                    "path": "com.amcis.SecurityPlatform.metainfo.xml"
                }
            ]
        }
    ]
}
